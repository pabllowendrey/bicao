<%= form_for(@customer, html: { class: "form-horizontal", role: "form" }) do |f| %>
  <% if @customer.errors.any? %>
    <div class="alert alert-danger alert-dismissable" role="alert">
      <button type="button" class="close" data-dismiss="alert"><span aria-hidden="true">&times;</span><span class="sr-only">Close</span></button>
      <h4>Verifique os erros abaixo:</h4>

      <ul>
      <% @customer.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :name, "Nome", class: "col-sm-2 control-label" %>
    <div class="col-sm-10">
      <%= f.text_field :name, class: "form-control" %>
    </div>
  </div>
  <div class="form-group">
    <%= f.label :cpf, "CPF", class: "col-sm-2 control-label" %>
    <div class="col-sm-10">
      <%= f.text_field :cpf, class: "form-control" %>
    </div>
  </div>
  <div class="form-group">
    <%= f.label :fone, class: "col-sm-2 control-label" %>
    <div class="col-sm-10">
      <%= f.text_field :fone, class: "form-control" %>
    </div>
  </div>
  <div class="form-group">
    <%= f.label :email, "E-mail", class: "col-sm-2 control-label" %>
    <div class="col-sm-10">
      <%= f.text_field :email, class: "form-control" %>
    </div>
  </div>
  <div class="form-group">
    <%= f.label :cep, "CEP", class: "col-sm-2 control-label" %>
    <div class="col-sm-10">
      <%= f.text_field :cep, class: "form-control" %>
    </div>
  </div>
  <div class="form-group">
    <%= f.label :address, "Endereço", class: "col-sm-2 control-label" %>
    <div class="col-sm-10">
      <%= f.text_field :address, class: "form-control" %>
    </div>
  </div>
  <div class="form-group">
    <%= f.label :number, "Número", class: "col-sm-2 control-label" %>
    <div class="col-sm-10">
      <%= f.text_field :number, class: "form-control" %>
    </div>
  </div>
  <div class="form-group">
    <%= f.label :district, "Setor", class: "col-sm-2 control-label" %>
    <div class="col-sm-10">
      <%= f.text_field :district, class: "form-control" %>
    </div>
  </div>
  <div class="form-group">
    <%= f.label :city, "Cidade", class: "col-sm-2 control-label" %>
    <div class="col-sm-10">
      <%= f.text_field :city, class: "form-control" %>
    </div>
  </div>
  <div class="form-group">
    <%= f.label :state, "Estado", class: "col-sm-2 control-label" %>
    <div class="col-sm-10">
      <%= f.text_field :state, class: "form-control" %>
    </div>
  </div>
  <div class="form-group">
    <div class="col-sm-offset-2 col-sm-10">
      <%= f.submit "Salvar", class: "btn btn-primary" %>
    </div>
  </div>
<% end %>
