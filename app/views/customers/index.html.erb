<div class="page-header">
  <%= link_to new_customer_path, class: 'btn btn-primary' do %>
    <span class="glyphicon glyphicon-plus"></span>
    New Customer
  <% end %>
  <h1>Lista customers</h1>
</div>

<div class="table-responsive">
  <table class="table table-striped table-bordered table-hover">
    <thead>
      <tr>
            <th>Nome</th>
            <th>CPF</th>
            <th>Fone</th>
            <th>E-mail</th>
            <th></th>
        <th></th>
        <th></th>
      </tr>
    </thead>

    <tbody>
      <%= content_tag_for(:tr, @customers) do |customer| %>
        <td><%= customer.name %></td>
        <td><%= customer.cpf %></td>
        <td><%= customer.fone %></td>
        <td><%= customer.email %></td>
        <td><%= link_to 'Mostrar', customer %></td>
        <td><%= link_to 'Editar', edit_customer_path(customer) %></td>
        <td><%= link_to 'Deletar', customer, method: :delete, data: { confirm: 'Confirmar?' } %></td>
      <% end %>
    </tbody>
  </table>
</div>
